        </mxCell>

        <mxCell id="rag" value="&lt;b&gt;2. Vector GraphRAG&lt;/b&gt;&lt;hr&gt;sentence-transformers&lt;br&gt;&lt;i&gt;(all-MiniLM-L6-v2)&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;strokeWidth=2;" vertex="1" parent="pipeline_group">
          <mxGeometry x="40" y="190" width="200" height="60" as="geometry" />
        </mxCell>

        <mxCell id="kb" value="&lt;b&gt;Clinical Ontology KB&lt;/b&gt;&lt;hr&gt;120+ Diseases&lt;br&gt;JSON Store" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#f8cecc;strokeColor=#b85450;strokeWidth=2;" vertex="1" parent="pipeline_group">
