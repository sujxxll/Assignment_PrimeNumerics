          <mxGeometry x="455" y="30" width="120" height="100" as="geometry" />
        </mxCell>

        <!-- AI Pipeline Container -->
        <mxCell id="pipeline_group" value="&lt;b style=&quot;font-size: 14px;&quot;&gt;Core AI Pipeline Execution&lt;/b&gt;" style="swimlane;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;strokeWidth=2;startSize=40;" vertex="1" parent="1">
