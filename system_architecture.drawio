        <mxCell id="frontend" value="&lt;b style=&quot;font-size: 14px;&quot;&gt;Frontend Presentation&lt;/b&gt;&lt;hr&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;ul&gt;&lt;li&gt;Next.js 16.2.1&lt;/li&gt;&lt;li&gt;React 19&lt;/li&gt;&lt;li&gt;Material UI (MUI)&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;align=center;verticalAlign=top;fillColor=#dae8fc;strokeColor=#6c8ebf;strokeWidth=2;spacingTop=4;spacingBottom=4;" vertex="1" parent="1">
